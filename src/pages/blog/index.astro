---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

// Fetch and sort blogs by publication date (newest first)
const posts = await getCollection('blog');
const sortedPosts = posts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const formatDate = (date: Date) => {
  return date.toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'long',
    day: 'numeric'
  });
};
---

<BaseLayout title="R&D Leadership & Engineering Blog | Atanu Roy">
  <section class="blog-header-section">
    <div class="container">
      <span class="blog-tag">Thought Leadership</span>
      <h1 class="blog-title">R&D & Engineering Blog</h1>
      <p class="blog-intro">Reflections on engineering leadership, product scale, system architecture, and agile software execution.</p>
    </div>
  </section>

  <section class="blog-list-section">
    <div class="container">
      <div class="posts-list">
        {sortedPosts.map(post => (
          <article class="post-item">
            <div class="post-meta">
              <span class="post-date">{formatDate(post.data.pubDate)}</span>
              {post.data.tags && (
                <div class="post-tags">
                  {post.data.tags.map(tag => (
                    <span class="tag-item">{tag}</span>
                  ))}
                </div>
              )}
            </div>
            <div class="post-info">
              <h2 class="post-heading">
                <a href={`/blog/${post.slug}`}>{post.data.title}</a>
              </h2>
              <p class="post-excerpt">{post.data.description}</p>
              <a href={`/blog/${post.slug}`} class="read-more-link">
                Read Article <i class="fa-solid fa-arrow-right"></i>
              </a>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .container {
    max-width: 800px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  /* Header Section */
  .blog-header-section {
    padding: 6rem 0 3rem 0;
    border-bottom: 1px solid var(--border-color);
  }

  .blog-tag {
    display: inline-block;
    font-size: 0.85rem;
    font-weight: 600;
    text-transform: uppercase;
    color: var(--accent);
    letter-spacing: 1.5px;
    margin-bottom: 0.5rem;
  }

  .blog-title {
    font-size: 3rem;
    line-height: 1.1;
    color: var(--text-primary);
    margin-bottom: 1rem;
  }

  .blog-intro {
    font-size: 1.2rem;
    color: var(--text-secondary);
    line-height: 1.6;
  }

  /* Blog List Section */
  .blog-list-section {
    padding: 4rem 0 6rem 0;
  }

  .posts-list {
    display: flex;
    flex-direction: column;
    gap: 4rem;
  }

  .post-item {
    display: grid;
    grid-template-columns: 200px 1fr;
    gap: 2.5rem;
    padding-bottom: 4rem;
    border-bottom: 1px dashed var(--border-color);
  }

  .post-item:last-child {
    border-bottom: none;
    padding-bottom: 0;
  }

  .post-meta {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .post-date {
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--text-secondary);
  }

  .post-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .tag-item {
    font-size: 0.75rem;
    font-weight: 600;
    padding: 0.25rem 0.6rem;
    background-color: var(--bg-secondary);
    border: 1px solid var(--border-color);
    border-radius: 4px;
    color: var(--text-secondary);
    text-transform: uppercase;
  }

  .post-info {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .post-heading {
    font-size: 1.8rem;
    font-weight: 700;
    text-transform: none;
    line-height: 1.3;
  }

  .post-heading a {
    color: var(--text-primary);
  }

  .post-heading a:hover {
    color: var(--accent);
  }

  .post-excerpt {
    font-size: 1.05rem;
    color: var(--text-secondary);
    line-height: 1.6;
  }

  .read-more-link {
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--accent);
    display: flex;
    align-items: center;
    gap: 0.4rem;
  }

  .read-more-link:hover {
    color: var(--accent-dark);
  }

  @media (max-width: 768px) {
    .post-item {
      grid-template-columns: 1fr;
      gap: 1rem;
      padding-bottom: 3rem;
    }
    .post-meta {
      flex-direction: row;
      justify-content: space-between;
      align-items: center;
    }
  }
</style>
